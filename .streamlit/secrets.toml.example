# App-wide default OpenAI-compatible configuration
OPENAI_BASE_URL = "https://ark.cn-beijing.volces.com/api/coding/v3"
OPENAI_API_KEY = "your_default_api_key_here"
OPENAI_MODEL = "kimi-k2.5"
OPENAI_TIMEOUT_SECONDS = 180
ENABLE_TEACHER_MODE = false

# Optional provider-specific presets
GROQ_API_KEY = ""
GROQ_API_BASE = "https://api.groq.com/openai/v1"
GROQ_MODEL = "llama-3.3-70b-versatile"

GEMINI_API_KEY = ""
GEMINI_API_BASE = "https://generativelanguage.googleapis.com/v1beta/openai/"
GEMINI_MODEL = "gemini-3-flash-preview"

OPENROUTER_API_KEY = ""
OPENROUTER_API_BASE = "https://openrouter.ai/api/v1"
OPENROUTER_MODEL = "openrouter/free"
# Optional but recommended for OpenRouter
OPENROUTER_HTTP_REFERER = ""
OPENROUTER_APP_TITLE = "Biomedical Signal Processing TA"

# Optional custom preset
CUSTOM_API_KEY = ""
CUSTOM_API_BASE = "https://api.openai.com/v1"
CUSTOM_MODEL = ""
